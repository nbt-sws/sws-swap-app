# API configuration
# Set to 'true' to use the in-memory mock fallback instead of the real backend.
VITE_USE_MOCK_API=false
# Default gateway / non-user service API
VITE_API_BASE_URL=http://localhost:3001/api/v1
# User service API (auth / users / queue)
VITE_USER_API_BASE_URL=https://sws-svc-user-production.up.railway.app/v1

# ─── App backend (Cloudflare worker, api/) ───
# Scanner service base URL (no trailing slash). Leave empty/unset to disable
# scanner integration — all scanner endpoints degrade gracefully when unset.
# SCANNER_SERVICE_URL=http://localhost:8088

