# API configuration
# Set to 'true' to use the in-memory mock fallback instead of the real backend.
VITE_USE_MOCK_API=false
# Default gateway / non-user service API
VITE_API_BASE_URL=http://localhost:3001/api/v1
# User service API (auth / users / queue)
VITE_USER_API_BASE_URL=https://sws-user-service-production.up.railway.app/v1
